# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD_PROD=your_secure_prod_password
POSTGRES_PASSWORD_SANDBOX=your_secure_sandbox_password

# ── Auth (Apple Sign-In) ──────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
APPLE_BUNDLE_ID=com.yourcompany.yourapp
# APPLE_WEB_CLIENT_ID=com.yourcompany.yourapp.web  # for admin panel Apple Sign-In

# ── Admin Panel ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# ADMIN_KEY=optional_api_key_for_dev_access

# ── Push Notifications (APNs) ─────────────────────────────────────────────
# APNS_KEY_PATH=AuthKey.p8
# APNS_KEY_ID=ABC123
# APNS_TEAM_ID=XYZ789
# APNS_ENVIRONMENT=production  # or "sandbox"

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=app@example.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=app@example.com
# SMTP_FROM_NAME=My App

# ── Environment ───────────────────────────────────────────────────────────
# ENVIRONMENT=production  # set by docker-compose per service
# PORT=8080               # set by docker-compose per service
